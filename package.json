{
  "name": "metaproof",
  "version": "0.2.0",
  "description": "Lint your iOS App Store metadata (the fastlane deliver metadata folder) for field-length and ASO keyword problems before you submit. Per-locale, Unicode-correct, zero dependencies, fully offline.",
  "type": "module",
  "bin": {
    "metaproof": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "node --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm test",
    "prepack": "npm run clean && npm run build"
  },
  "keywords": [
    "ios",
    "app-store",
    "app-store-connect",
    "fastlane",
    "deliver",
    "metadata",
    "aso",
    "keywords",
    "linter",
    "localization",
    "ci"
  ],
  "author": "TheChosenVictor LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vsolano9/metaproof.git"
  },
  "bugs": {
    "url": "https://github.com/vsolano9/metaproof/issues"
  },
  "homepage": "https://github.com/vsolano9/metaproof#readme",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
